        "@octokit/plugin-throttling": "^11.0.1",
        "@octokit/rest": "^22.0.0",
        "@octokit/types": "^16.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "@vitest/coverage-v8": "^4.1.6",
        "esbuild": "^0.28.0",
        "eslint": "^10.4.0",
        "fast-check": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "vitest": "^4.1.5",
        "vitest-mock-extended": "^4.0.0"
    }
