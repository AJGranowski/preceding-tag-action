    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "bundle": "node esbuild.config.mjs",
        "check-types": "tsc -noEmit",
        "format": "eslint --fix",
        "fuzz": "vitest run --project fuzz --coverage.thresholds false",
